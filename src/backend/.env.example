# --- DATABASE (Local Docker PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5433
DB_USER=unihub
DB_PASSWORD=your_db_password_here
DB_NAME=unihub_workshop
DB_SSLMODE=disable

# --- DATABASE (Supabase - backup) ---
# DB_HOST=db.your-supabase-url.supabase.co
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=your_supabase_password
# DB_NAME=postgres
# DB_SSLMODE=require

# --- INFRASTRUCTURE (Redis & RabbitMQ) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# --- SECURITY & AUTH ---
AUTH_SECRET=your_jwt_secret_key_here

# --- RSA KEYS (DÙNG CHO VÉ QR & MOBILE VERIFY) ---
RSA_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
your_rsa_private_key_here
-----END RSA PRIVATE KEY-----"

RSA_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
your_rsa_public_key_here
-----END PUBLIC KEY-----"

# --- AI CONFIG (GOOGLE GEMINI) ---
GEMINI_API_KEY=your_google_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash
AI_TEMPERATURE=0.4
AI_MAX_TOKENS=16384

# --- PAYMENT MOCK ---
PAYMENT_GATEWAY_URL=http://localhost:8080/mock/payment
PAYMENT_WEBHOOK_SECRET=your_payment_webhook_secret_here

# --- SMTP EMAIL (GMAIL) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_FROM=your_email@gmail.com
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password_here

# --- SERVER & OTHERS ---
SERVER_PORT=8080
CORS_ORIGINS=http://localhost:3000
CSV_IMPORT_DIR=./data/imports
CSV_ARCHIVE_DIR=./data/archive
RATE_LIMIT_CAPACITY=5000
RATE_LIMIT_REFILL_RATE=1000
RATE_LIMIT_TTL=300
